            "value": "Default is ⌘⇧6. The hotkey works while Captzo is running."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El valor predeterminado es ⌘⇧6. El atajo funciona mientras Captzo está en ejecución."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "默认为 ⌘⇧6。Captzo 运行时快捷键可用。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デフォルトは ⌘⇧6 です。Captzo の実行中にホットキーが機能します。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Standard ist ⌘⇧6. Der Kurzbefehl funktioniert, während Captzo läuft."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Par défaut : ⌘⇧6. Le raccourci fonctionne tant que Captzo est lancé."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O padrão é ⌘⇧6. O atalho funciona enquanto o Captzo estiver em execução."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기본값은 ⌘⇧6입니다. Captzo가 실행 중일 때 단축키가 작동합니다."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الافتراضي هو ⌘⇧6. يعمل الاختصار أثناء تشغيل Captzo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डिफ़ॉल्ट ⌘⇧6 है। Captzo चलते समय हॉटकी काम करती है।"
          }
        }
      }
