    "Capture with a preset aspect ratio from the menu bar, or start one here." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "التقط بنسبة عرض إلى ارتفاع مسبقة من شريط القائمة، أو ابدأ من هنا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erfassen Sie mit einem voreingestellten Seitenverhältnis über die Menüleiste oder starten Sie hier."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Capture with a preset aspect ratio from the menu bar, or start one here."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Captura con una relación de aspecto predefinida desde la barra de menús, o inicia una aquí."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Capturez avec un format prédéfini depuis la barre des menus, ou démarrez ici."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "मेनू बार से प्रीसेट आस्पेक्ट अनुपात से कैप्चर करें, या यहाँ से शुरू करें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "メニューバーのプリセット比率でキャプチャするか、ここから開始します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "메뉴 막대에서 미리 설정된 화면비로 캡처하거나 여기서 시작하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Capture com uma proporção predefinida na barra de menus ou inicie aqui."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "从菜单栏使用预设宽高比截图，或在此处开始。"
          }
        }
      }
    },
    "Captzo" : {
      "comment" : "The title of the application.",
      "isCommentAutoGenerated" : true
    },
    "Captzo needs Screen Recording access to capture screenshots with aspect-ratio selection." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحتاج Captzo إلى إذن تسجيل الشاشة لالتقاط لقطات مع اختيار نسبة العرض إلى الارتفاع."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Captzo benötigt Zugriff auf die Bildschirmaufnahme, um Screenshots mit Seitenverhältnis-Auswahl zu erstellen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Captzo needs Screen Recording access to capture screenshots with aspect-ratio selection."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Captzo necesita acceso a Grabación de pantalla para capturar capturas con selección de relación de aspecto."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Captzo a besoin de l’accès à l’enregistrement d’écran pour capturer des images avec sélection du format."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आस्पेक्ट अनुपात चयन के साथ स्क्रीनशॉट के लिए Captzo को स्क्रीन रिकॉर्डिंग पहुँच चाहिए।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Captzo はアスペクト比選択付きのスクリーンショットに画面収録へのアクセスが必要です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Captzo는 화면비 선택 스크린샷을 위해 화면 기록 접근 권한이 필요합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Captzo precisa de acesso à Gravação de tela para capturar com seleção de proporção."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Captzo 需要屏幕录制权限才能按宽高比截取屏幕。"
          }
        }
      }
    },
