    "permission.banner.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بدون هذا الإذن لا يمكن أن تعمل طبقة الالتقاط. فعّل Captzo في إعدادات النظام ← الخصوصية والأمن ← تسجيل الشاشة، ثم أعد تشغيل Captzo."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ohne diese Berechtigung funktioniert die Aufnahmeüberlagerung nicht. Aktivieren Sie Captzo unter Systemeinstellungen → Datenschutz & Sicherheit → Bildschirmaufnahme und starten Sie Captzo neu."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Without this permission the capture overlay cannot work. Enable Captzo in System Settings → Privacy & Security → Screen Recording, then quit and relaunch Captzo."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sin este permiso, la superposición de captura no puede funcionar. Activa Captzo en Ajustes del Sistema → Privacidad y seguridad → Grabación de pantalla, luego cierra y vuelve a abrir Captzo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sans cette autorisation, la superposition de capture ne peut pas fonctionner. Activez Captzo dans Réglages Système → Confidentialité et sécurité → Enregistrement de l’écran, puis quittez et relancez Captzo."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "इस अनुमति के बिना कैप्चर ओवरले काम नहीं कर सकता। सिस्टम सेटिंग्ज़ → गोपनीयता और सुरक्षा → स्क्रीन रिकॉर्डिंग में Captzo सक्षम करें, फिर Captzo बंद कर फिर से खोलें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この許可がないとキャプチャオーバーレイは機能しません。システム設定 → プライバシーとセキュリティ → 画面収録で Captzo を有効にし、Captzo を終了して再起動してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 권한이 없으면 캡처 오버레이가 작동하지 않습니다. 시스템 설정 → 개인 정보 보호 및 보안 → 화면 기록에서 Captzo를 활성화한 다음 Captzo를 종료했다가 다시 실행하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sem esta permissão, a sobreposição de captura não funciona. Ative o Captzo em Ajustes do Sistema → Privacidade e segurança → Gravação de tela e reinicie o Captzo."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "没有此权限，截图叠加层无法工作。请在系统设置 → 隐私与安全性 → 屏幕录制中启用 Captzo，然后退出并重新打开 Captzo。"
          }
        }
      }
    },
    "permission.denied.message" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يلزم إذن تسجيل الشاشة. فعّل Captzo في إعدادات النظام ← الخصوصية والأمن ← تسجيل الشاشة. %@"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berechtigung für Bildschirmaufnahme erforderlich. Aktivieren Sie Captzo unter Systemeinstellungen → Datenschutz & Sicherheit → Bildschirmaufnahme. %@"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Screen Recording permission is required. Enable Captzo in System Settings → Privacy & Security → Screen Recording. %@"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se requiere permiso de Grabación de pantalla. Activa Captzo en Ajustes del Sistema → Privacidad y seguridad → Grabación de pantalla. %@"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L’autorisation d’enregistrement d’écran est requise. Activez Captzo dans Réglages Système → Confidentialité et sécurité → Enregistrement de l’écran. %@"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "स्क्रीन रिकॉर्डिंग अनुमति आवश्यक है। सिस्टम सेटिंग्ज़ → गोपनीयता और सुरक्षा → स्क्रीन रिकॉर्डिंग में Captzo सक्षम करें। %@"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "画面収録の許可が必要です。システム設定 → プライバシーとセキュリティ → 画面収録で Captzo を有効にしてください。%@"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "화면 기록 권한이 필요합니다. 시스템 설정 → 개인 정보 보호 및 보안 → 화면 기록에서 Captzo를 활성화하세요. %@"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "É necessária a permissão de Gravação de tela. Ative o Captzo em Ajustes do Sistema → Privacidade e segurança → Gravação de tela. %@"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "需要屏幕录制权限。请在系统设置 → 隐私与安全性 → 屏幕录制中启用 Captzo。%@"
          }
        }
      }
    },
    "permission.restart.hint" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بعد منح أو تغيير إذن تسجيل الشاشة، أنهِ Captzo وأعد تشغيله ليكتمل الالتقاط."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nach dem Erteilen oder Ändern der Berechtigung für Bildschirmaufnahme Captzo beenden und neu starten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "After granting or changing Screen Recording permission, quit Captzo and relaunch it for capture to work."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Después de conceder o cambiar el permiso de Grabación de pantalla, cierra Captzo y vuelve a abrirlo para que la captura funcione."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Après avoir accordé ou modifié l’autorisation d’enregistrement d’écran, quittez et relancez Captzo pour que la capture fonctionne."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "स्क्रीन रिकॉर्डिंग अनुमति देने या बदलने के बाद कैप्चर के लिए Captzo बंद कर फिर से खोलें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "画面収録の許可を付与または変更したら、キャプチャを機能させるために Captzo を終了して再起動してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "화면 기록 권한을 허용하거나 변경한 후 캡처가 작동하려면 Captzo를 종료했다가 다시 실행하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Após conceder ou alterar a permissão de Gravação de tela, saia e reabra o Captzo para a captura funcionar."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "授予或更改屏幕录制权限后，请退出并重新打开 Captzo 以使截图生效。"
          }
        }
      }
    },
